# Kopiere diese Datei zu .env und trage deine Werte ein

# Pflichtfeld: Anthropic API-Key (von console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-dein-api-key-hier

# Optional: Pfad zur Excel-Datei (Standard: data/input/fonds_universe.xlsx)
# EXCEL_PATH=C:\Users\Dein Name\Desktop\Fonds.xlsx

# Optional: Ordner für PDF-Downloads (Standard: data/prospectus)
# PDF_FOLDER=C:\FundProspects

# Optional: Anzahl ISINs pro Lauf (Standard: 200)
# BATCH_SIZE=200

# Optional: Claude-Modell für Batch-Verarbeitung (Standard: claude-haiku-4-5-20251001)
# Haiku = günstig/schnell | Sonnet = ausgewogen | Opus = teuer/präzise
# CLAUDE_BATCH_MODEL=claude-haiku-4-5-20251001

# Optional: Claude-Modell für Einzel-PDF-Analyse (Standard: claude-sonnet-4-6)
# CLAUDE_SINGLE_MODEL=claude-sonnet-4-6
