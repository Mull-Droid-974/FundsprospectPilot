# Kopiere diese Datei zu .env und trage deine Werte ein

# Pfad zur bestehenden results.db aus FundProspektPilot
# Standard: sucht relative zur aktuellen Position
DB_PATH=C:\FundProspektPilot\data\output\results.db

# Ordner für heruntergeladene Prospekte
PDF_FOLDER=C:\FundProspektDownloader\data\prospekte

# Wartezeit zwischen fundinfo.com Anfragen in Sekunden (Standard: 1.5)
# REQUEST_DELAY=1.5
